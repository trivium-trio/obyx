{
  "name": "@circle-fin/developer-controlled-wallets",
  "main": "./dist/developer-controlled-wallets.cjs.js",
  "types": "./dist/types/developer-controlled-wallets.d.ts",
  "module": "./dist/developer-controlled-wallets.es.js",
  "exports": {
    ".": {
      "types": "./dist/types/developer-controlled-wallets.d.ts",
      "import": "./dist/developer-controlled-wallets.es.js",
      "require": "./dist/developer-controlled-wallets.cjs.js"
    },
    "./solana/kit": {
      "types": "./dist/types/solana/kit.d.ts",
      "import": "./dist/solana/kit.es.js",
