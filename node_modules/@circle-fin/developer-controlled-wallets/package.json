    },
    "./solana/web3": {
      "types": "./dist/types/solana/web3.d.ts",
      "import": "./dist/solana/web3.es.js",
      "require": "./dist/solana/web3.cjs.js"
    },
    "./evm": {
      "types": "./dist/evm/types/evm.d.ts",
      "import": "./dist/evm/evm.es.js",
      "require": "./dist/evm/evm.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "axios": "^1.15.0"
  },
  "peerDependencies": {
    "@solana/codecs-strings": "^2.0.0",
    "@solana/kit": "^2.1.0 || ^3.0.0 || ^4.0.0 || ^5.0.0 || ^6.0.0",
    "@solana/web3.js": "^1.63.0"
  },
  "peerDependenciesMeta": {
    "@solana/codecs-strings": {
      "optional": true
    },
    "@solana/kit": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    }
  },
  "version": "10.8.0",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.4",
    "@solana/codecs-strings": "^2.0.0",
    "@solana/kit": "^6.9.0",
    "@solana/web3.js": "^1.63.0",
    "eslint": "^8.49.0",
    "viem": "^2.0.0",
    "vitest": "^4.1.0",
    "@circle-fin/smart-contract-platform": "10.8.0",
    "@shared/eslint-config": "1.0.0",
    "@shared/rollup": "0.0.1",
    "@shared/clients": "1.0.0",
    "@shared/tsconfig": "2.0.1",
    "@shared/core": "0.0.1",
    "@shared/vitest": "0.0.0"
